generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  image              String?
  passwordHash       String?
  emailVerified      DateTime?

  defaultTimerMode   TimerMode @default(POMODORO)
  pomodoroMinutes    Int       @default(25)
  shortBreakMinutes  Int       @default(5)
  longBreakMinutes   Int       @default(15)
  dailyGoalMinutes   Int       @default(120)

  currentStreak        Int       @default(0)
  longestStreak        Int       @default(0)
  lastActiveDate       DateTime?
  streakFreezeCount    Int       @default(1)
  lastStreakFreezeUsed DateTime?
  pushToken            String?
  onboardingComplete   Boolean   @default(false)
  persona              String?
  firstSessionAt       DateTime?
  longestSession       Int       @default(0)
  bestDayMinutes       Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      AuthSession[]
  tasks         Task[]
  focusSessions FocusSession[]
  coachMessages CoachMessage[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Task {
  id               String     @id @default(cuid())
  userId           String
  title            String
  description      String?
  priority         Priority   @default(P3)
  status           TaskStatus @default(TODO)
  tags             String[]
  estimatedMinutes Int?
  actualMinutes    Int        @default(0)
  sortOrder        Int        @default(0)
  dueDate          DateTime?
  completedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions FocusSession[]

  @@index([userId, status])
  @@index([userId, dueDate])
  @@map("tasks")
}

model FocusSession {
  id             String        @id @default(cuid())
  userId         String
  taskId         String?
  mode           TimerMode
  status         SessionStatus @default(ACTIVE)
  startedAt      DateTime      @default(now())
  endedAt        DateTime?
  plannedMinutes Int?
  actualMinutes  Int           @default(0)
  breakMinutes   Int           @default(0)
  note           String?
  mood           Int?

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@map("focus_sessions")
}

model CoachMessage {
  id        String      @id @default(cuid())
  userId    String
  role      MessageRole
  content   String
  context   Json?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("coach_messages")
}

enum TimerMode {
  POMODORO
  FLOWTIME
}

enum Priority {
  P1
  P2
  P3
  P4
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}
